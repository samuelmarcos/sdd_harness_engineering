{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(**)",
      "Edit(specs/**)",
      "Write(specs/**)",
      "Edit(progress/**)",
      "Write(progress/**)",
      "Edit(.claude/session-context/**)",
      "Write(.claude/session-context/**)",
      "Edit(.claude/knowledge/**)",
      "Write(.claude/knowledge/**)",
      "Edit(.sdd/**)",
      "Write(.sdd/**)",
      "Edit(tests/**)",
      "Write(tests/**)",
      "Bash(npm run build)",
      "Bash(npm run lint)",
      "Bash(npm test)",
      "Bash(npm run test:*)",
      "Bash(python3 .sdd/sdd.py *)",
      "Bash(python3 -m unittest discover -s tests/harness*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)"
    ],
    "ask": [
      "Edit(src/**)",
      "Bash(git commit*)",
      "Bash(git push*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/credentials.json)",
      "Read(.mcp.json)",
      "Read(**/*-key.json)",
      "Read(**/service-account*.json)",
      "Bash(git push --force*)",
      "Bash(rm -rf*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-tool-use.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  },
  "env": {
    "SDD_ENFORCE": "true"
  }
}
